{
  "name": "lernsaathi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test:unit": "node --experimental-strip-types tests/unit/pipeline-helpers.test.ts && node --experimental-strip-types tests/unit/decision-contract.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test:unit && npm run check:policy && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "eval": "node eval/run.mjs",
    "check:policy": "node scripts/check-policy.mjs",
    "validate:constraints": "node scripts/validate-constraints.mjs",
    "validate:slice": "node scripts/validate-constraints.mjs",
    "evidence:init": "node scripts/collect-evidence.mjs init",
    "evidence:mark": "node scripts/collect-evidence.mjs mark",
    "evidence:status": "node scripts/collect-evidence.mjs status",
    "evidence:report": "node scripts/collect-evidence.mjs report"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "lucide-react": "^1.14.0",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.31",
    "openai": "^6.36.0",
    "pino": "^10.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.6",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3"
  }
}
